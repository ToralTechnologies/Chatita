# Database
DATABASE_URL="postgresql://user:password@host:5432/chatita?sslmode=require"

# Auth
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Access Control - Email Allowlist (REQUIRED for security)
# IMPORTANT: Comma-separated list of authorized emails (no spaces)
# If empty, ALL access is blocked for security
# Example: ALLOWED_EMAILS=user1@example.com,user2@example.com
ALLOWED_EMAILS=""

# Optional: Google OAuth (only enabled if credentials are set)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Feature Flags
ENABLE_AI_ANALYSIS=false
ENABLE_AI_CHAT=false
ENABLE_GOOGLE_PLACES=false

# AI Services - Using Claude (Anthropic)
# ENABLE_AI_ANALYSIS uses Claude 3.5 Sonnet for meal photo analysis
# ENABLE_AI_CHAT uses Claude for conversational assistance
ANTHROPIC_API_KEY=""

# Google Services (only needed if ENABLE_GOOGLE_PLACES=true)
GOOGLE_MAPS_API_KEY=""

# File Storage (optional)
BLOB_READ_WRITE_TOKEN=""

# Email / SMTP Configuration (for weekly reports)
# Use Gmail SMTP or your preferred email service
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM='"Chatita" <noreply@chatita.app>'

# Cron Job Security (for automated weekly reports)
# Generate a secure random string: openssl rand -base64 32
CRON_SECRET=""

# App URL (for email links and redirects)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Dexcom CGM Integration (optional)
# Register your app at https://developer.dexcom.com
# Use 'sandbox' for testing, 'production' for real data
DEXCOM_CLIENT_ID=""
DEXCOM_CLIENT_SECRET=""
DEXCOM_ENVIRONMENT="sandbox"  # 'sandbox' or 'production'
DEXCOM_REDIRECT_URI="http://localhost:3000/api/dexcom/callback"

# Encryption key for CGM credentials and OAuth tokens at rest (AES-256-GCM)
# Used by: LibreIntegration, HealthConnection (Google Health tokens)
# Generate: openssl rand -hex 32
ENCRYPTION_KEY=""

# ── Google Health API / Fitbit Integration ────────────────────────────────────
# Google Health API replaces both Google Fit API and legacy Fitbit Web API.
# Legacy Fitbit Web API is scheduled for shutdown in September 2026.
# Apply for Google Health API access at: https://developers.google.com/health
#
# OAuth setup:
# 1. Go to https://console.cloud.google.com → create project
# 2. Enable "Fitness API" (for now; update to Health API when GA)
# 3. Create OAuth 2.0 credentials (Web application type)
# 4. Add authorized redirect URI: http://localhost:3000/api/health/google/callback
# 5. Copy client ID and secret below
#
# NOTE: The Google Health API is in limited developer access as of June 2026.
# You must apply for access before production use (developers.google.com/health).
# For local testing, the Google Fitness API works with the same OAuth credentials.
GOOGLE_HEALTH_CLIENT_ID=""
GOOGLE_HEALTH_CLIENT_SECRET=""
GOOGLE_HEALTH_REDIRECT_URI="http://localhost:3000/api/health/google/callback"

# Apple Health import file size limit (MB). Default: 50.
# Apple Health exports can be several hundred MB for long-time users.
HEALTH_IMPORT_MAX_FILE_SIZE_MB=50

# (Public — passed to browser for display only)
NEXT_PUBLIC_HEALTH_IMPORT_MAX_MB=50

# FreeStyle Libre CGM Integration (optional)
# No registration needed - uses LibreLinkUp credentials directly
# Users connect with their LibreLinkUp email/password in the app
# Region: US, EU, or AP (Asia-Pacific)
