// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  password          String?   // Made optional for OAuth users
  name              String?
  emailVerified     DateTime? // Required for NextAuth
  image             String?   // Profile picture from OAuth
  diabetesType      String?   // Type1, Type2, Gestational, PreDiabetes, Other
  targetGlucoseMin  Int       @default(70)
  targetGlucoseMax  Int       @default(180)
  preferredLanguage String    @default("en") // en, es
  weeklyReportEnabled Boolean @default(true) // Send weekly progress emails
  lastReportSent    DateTime? // Track last email sent
  tier              String    @default("free") // 'free' | 'pro' | 'unlimited'
  subscriptionId    String?
  subscriptionEnds  DateTime?

  // Extended health profile — for personalized guidance
  age               Int?
  heightCm          Float?              // centimeters
  weightKg          Float?              // kilograms
  // Backward-compatible: old values (sedentary/light/moderate/active/very_active) still stored as-is
  // New preferred values: mostly_sitting | lightly_active | moderately_active | very_active | not_sure | prefer_not_to_say
  activityLevel     String?
  weightGoal        String?             // 'lose' | 'gain' | 'maintain'
  otherConditions   String?   @db.Text  // JSON array: ["heart_disease","kidney_disease","hypertension"]
  currentMedications String?  @db.Text  // JSON array of medication names
  dailyCalorieTarget Int?
  dailyCarbTarget    Int?               // grams per day
  mealsPerDay        Int?     @default(3)

  // Movement & Activity Profile — all fields optional
  preferredMovementTypes String?   @db.Text   // JSON array: ["walking","chores","dancing",...]
  exerciseFrequency      String?              // 'daily'|'most_days'|'few_times_week'|'rarely'|'never'|'not_sure'
  averageDailySteps      Int?
  hasPhysicalJob         Boolean?  @default(false)
  mobilityLimitations    String?   @db.Text   // free-text
  movementGoal           String?              // 'more_energy'|'manage_glucose'|'lose_weight'|'feel_better'|'other'
  movementNotes          String?   @db.Text   // free-text

  // Cultural Food Profile — all fields optional, user-driven
  countryOrRegion          String?              // e.g. "Mexico", "India", "Nigeria"
  culturalFoodBackground   String?   @db.Text   // free-text: "I grew up eating ..."
  commonMeals              String?   @db.Text   // JSON array of typical meals
  stapleCarbs              String?   @db.Text   // JSON array: ["tortillas","rice","beans"]
  commonProteins           String?   @db.Text   // JSON array: ["chicken","beans","eggs"]
  commonVegetables         String?   @db.Text   // JSON array
  commonDrinks             String?   @db.Text   // JSON array: ["agua fresca","horchata","tea"]
  dietaryRestrictions      String?   @db.Text   // JSON array: ["halal","vegetarian","kosher","lactose-free"]
  religiousFoodNeeds       String?              // free-text, optional
  foodBudgetLevel          String?              // 'low' | 'medium' | 'high'
  foodAccessContext        String?              // 'food_pantry' | 'grocery' | 'restaurant_heavy' | 'mixed'
  cookingFrequency         String?              // 'rarely' | 'sometimes' | 'often' | 'daily'
  foodPantryUse            Boolean?  @default(false)
  comfortFoods             String?   @db.Text   // JSON array — foods user finds comfort in
  foodsToKeep              String?   @db.Text   // JSON array — foods user does not want to give up

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  meals             Meal[]
  glucoseEntries    GlucoseEntry[]
  moodEntries       MoodEntry[]
  chatMessages      ChatMessage[]
  badges            UserBadge[]
  accounts          Account[] // OAuth accounts
  sessions          Session[] // NextAuth sessions
  customFoods       CustomFood[]
  recipes           Recipe[]
  mealPlans         MealPlan[]
  favoriteRestaurants FavoriteRestaurant[]
  restaurantVisits    RestaurantVisit[]
  dexcomIntegration   DexcomIntegration?
  libreIntegration    LibreIntegration?
  mealFollowUps       MealFollowUp[]
  chatPreference      ChatPreference?
  aiUsage             AiUsage[]
  hydrationLogs       HydrationLog[]
  guidanceInsights    GuidanceInsight[]
  activityLogs        ActivityLog[]
}

// NextAuth models for OAuth and session management
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Meal {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  photoUrl      String?   // or base64 blob
  photoBase64   String?   @db.Text
  detectedFoods String?   @db.Text // JSON array
  foodEntries   FoodEntry[] // Detailed individual foods in this meal

  // AI-first fields
  aiSummary     String?   // "chicken tacos with salsa"
  aiConfidence  Int?      // 0-100
  aiMode        String?   // 'ai' | '$0'
  nutritionSource String? @default("manual") // 'ai' | 'manual' | 'user-edited' | 'usda' | 'barcode'

  // Meal identity
  mealName      String?   // User-provided name e.g. "Curry chicken with rice"
  source        String?   // home, restaurant, packaged, food_pantry, leftovers, other
  portionEatenPercent Float? // 25, 50, 75, 100, or custom
  estimateConfidence  String? // exact, estimated, not_sure
  timeFinished  DateTime?

  // Core nutrition
  calories      Float?
  carbs         Float?
  protein       Float?
  fat           Float?
  fiber         Float?
  sugar         Float?
  sodium        Float?
  portionSize   String?

  // Extended nutrition
  addedSugar    Float?
  saturatedFat  Float?
  transFat      Float?
  cholesterol   Float?
  potassium     Float?

  // Restaurant location tracking
  restaurantName    String?
  restaurantAddress String?
  restaurantPlaceId String?

  // Glucose context
  preMealGlucose   Float?
  postMealGlucose  Float?   // 2-hour reading
  cgmTrend         String?  // rising, stable, falling
  glucoseSymptoms  String?  @db.Text // JSON array

  // Medication context
  medicationTaken  Boolean?
  medicationName   String?
  medicationDose   String?
  medicationTime   String?  // "08:00" format
  medicationNotes  String?  @db.Text
  isGlp1           Boolean?
  glp1Symptoms     String?  @db.Text // JSON array

  // Snack context
  snackReason              String?  // hungry, craving, low_glucose, before_exercise, after_exercise, nausea, need_more_protein, routine, other
  wasLowGlucoseTreatment   Boolean?

  feeling       String?   @db.Text // How user felt after meal
  mealType      String?   // breakfast, lunch, dinner, snack
  eatenAt       DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  relatedGlucoseReadings GlucoseEntry[]
  hydrationLogs          HydrationLog[]
  moodEntries            MoodEntry[]
  followUp               MealFollowUp?

  @@index([userId, eatenAt])
}

// NEW: Individual food items within a meal
model FoodEntry {
  id          String @id @default(cuid())
  mealId      String
  meal        Meal   @relation(fields: [mealId], references: [id], onDelete: Cascade)

  foodName    String
  brand       String?
  barcode     String? // UPC/EAN for barcode-scanned items

  // Nutrition per serving
  servingSize     String  // "1 cup", "100g", etc
  servingsEaten   Float   @default(1)

  calories    Float
  carbs       Float
  protein     Float
  fat         Float
  fiber       Float?
  sugar       Float?
  sodium      Float?

  // Data source tracking
  source      String  @default("manual") // 'usda' | 'barcode' | 'custom' | 'manual' | 'ai'
  fdcId       String? // USDA FoodData Central ID
  upcCode     String? // Barcode UPC code

  createdAt   DateTime @default(now())

  @@index([mealId])
  @@index([barcode])
}

// NEW: USDA and barcode-scanned food database cache
model FoodDatabase {
  id          String @id @default(cuid())

  foodName    String
  foodNameEs  String? // Spanish translation
  brand       String?
  barcode     String? @unique // UPC/EAN

  // Nutrition per 100g or standard serving
  servingSize     String  // "100g", "1 cup", etc
  calories    Float
  carbs       Float
  protein     Float
  fat         Float
  fiber       Float?
  sugar       Float?
  sodium      Float?

  // Additional micronutrients (optional)
  vitaminA    Float?
  vitaminC    Float?
  calcium     Float?
  iron        Float?

  // Source tracking
  source      String  // 'usda' | 'openfoodfacts' | 'custom'
  fdcId       String? // USDA FoodData Central ID
  lastFetched DateTime @default(now())

  // Diabetes-specific flags
  isLowCarb   Boolean @default(false)
  isLowGI     Boolean @default(false)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([foodName])
  @@index([barcode])
  @@index([fdcId])
}

// NEW: User's custom foods
model CustomFood {
  id          String @id @default(cuid())
  userId      String
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  foodName    String
  brand       String?

  servingSize     String
  calories    Float
  carbs       Float
  protein     Float
  fat         Float
  fiber       Float?
  sugar       Float?
  sodium      Float?

  notes       String? @db.Text
  createdAt   DateTime @default(now())

  @@index([userId])
}

// NEW: User's custom recipes
model Recipe {
  id          String @id @default(cuid())
  userId      String
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String
  nameEs      String?
  description String? @db.Text
  photoUrl    String?

  servings    Int     @default(1)
  prepTime    Int?    // minutes
  cookTime    Int?    // minutes

  ingredients String  @db.Text // JSON array of {foodName, amount, unit}
  instructions String @db.Text // JSON array of steps

  // Total nutrition per serving
  calories    Float
  carbs       Float
  protein     Float
  fat         Float
  fiber       Float?
  sugar       Float?
  sodium      Float?

  tags        String? @db.Text // JSON array: ["breakfast", "low-carb", "mexican"]

  // Diabetes-specific
  carbCount   String? // "15g per serving"
  diabetesTips String? @db.Text

  isPublic    Boolean @default(false) // Share with community?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

// NEW: Meal planning
model MealPlan {
  id          String @id @default(cuid())
  userId      String
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String  // "Week 1" or "Budget Friendly February"
  startDate   DateTime
  endDate     DateTime

  meals       String  @db.Text // JSON: {day: date, meals: [{type, recipeId, notes}]}

  groceryList String? @db.Text // JSON array of items

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

model GlucoseEntry {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  value     Float    // mg/dL

  // NEW: Context fields
  context   String?  // 'fasting' | 'pre-meal' | 'post-meal' | 'bedtime' | 'random'
  relatedMealId String? // Link to the meal if post-meal reading
  relatedMeal   Meal?   @relation(fields: [relatedMealId], references: [id], onDelete: SetNull)

  notes     String?
  measuredAt DateTime @default(now())
  createdAt DateTime @default(now())

  @@index([userId, measuredAt])
  @@index([relatedMealId])
}

model MoodEntry {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  mood        String   // happy, grateful, calm, neutral, tired, anxious, sad
  stressLevel Int      // 1-10

  // Contextual flags (legacy — kept for backward compat)
  notFeelingWell     Boolean @default(false)
  onPeriod           Boolean @default(false)
  feelingOverwhelmed Boolean @default(false)
  havingCravings     Boolean @default(false)

  // Extended mood fields
  moodIntensity      Int?    // 1-10
  energyLevel        Int?    // 1-10
  hungerLevel        Int?    // 1-10
  fullnessLevel      Int?    // 1-10
  cravings           String? @db.Text // JSON array: ["sweet","salty","carbs"]
  symptoms           String? @db.Text // JSON array: ["headache","nausea","tired"]
  contextTags        String? @db.Text // JSON array: ["poor_sleep","high_stress","injection_day"]

  // Free-text user voice
  userWords          String? @db.Text // "I feel overwhelmed because I had class"
  foodMoodConnection String? @db.Text // "I didn't drink water and skipped breakfast"
  supportWanted      String? @db.Text // "Give me a quick snack idea"

  // AI summary (generated separately, not overwriting user words)
  aiSummary          String? @db.Text

  // Optional link to a meal
  mealId      String?
  meal        Meal?    @relation(fields: [mealId], references: [id], onDelete: SetNull)

  notes       String?  @db.Text
  recordedAt  DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([userId, recordedAt])
  @@index([mealId])
}

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  role      String   // user, assistant
  content   String   @db.Text

  // Context at time of message
  userContext String? @db.Text // JSON: {mood, onPeriod, feelingOverwhelmed, etc}

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model Badge {
  id          String      @id @default(cuid())
  name        String      @unique
  nameEs      String      // Spanish translation
  description String
  descriptionEs String
  icon        String      // emoji or icon name
  daysRequired Int

  users       UserBadge[]
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badgeId   String
  badge     Badge    @relation(fields: [badgeId], references: [id])

  unlockedAt DateTime @default(now())

  @@unique([userId, badgeId])
  @@index([userId])
}

// Restaurant tracking
model FavoriteRestaurant {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Restaurant details
  placeId       String   // Google Place ID or simulated ID
  name          String
  address       String?
  cuisine       String?
  rating        Float?
  priceLevel    Int?     // 1-4

  // User notes
  notes         String?  @db.Text
  tags          String?  @db.Text // JSON array: ["low-carb", "quick", "family-friendly"]

  createdAt     DateTime @default(now())

  @@unique([userId, placeId])
  @@index([userId])
}

model RestaurantVisit {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Restaurant details (denormalized for quick access)
  placeId       String   // Google Place ID or simulated ID
  name          String
  address       String?
  cuisine       String?

  // Visit tracking
  visitedAt     DateTime @default(now())
  mealId        String?  // Link to meal if user logged it

  // Performance metrics (for recommendations)
  glucoseImpact String?  // 'low' | 'medium' | 'high' based on post-meal glucose

  @@index([userId, visitedAt])
  @@index([userId, placeId])
}

// Dexcom CGM Integration
model DexcomIntegration {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // OAuth tokens
  accessToken     String   @db.Text
  refreshToken    String   @db.Text
  tokenExpiresAt  DateTime

  // Dexcom user info
  dexcomUserId    String?  // Dexcom's user identifier

  // Sync settings
  autoSync        Boolean  @default(true)
  lastSyncAt      DateTime?
  syncFrequency   Int      @default(15) // minutes

  // Environment (sandbox vs production)
  environment     String   @default("production") // 'sandbox' | 'production'

  // Connection status
  isActive        Boolean  @default(true)
  lastError       String?  @db.Text

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
}

// FreeStyle Libre CGM Integration (via LibreLinkUp)
model LibreIntegration {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // LibreLinkUp credentials (encrypted)
  libreEmail      String   @db.Text
  librePassword   String   @db.Text // Encrypted password

  // Session token
  authToken       String?  @db.Text
  tokenExpiresAt  DateTime?

  // Libre user info
  libreUserId     String?  // LibreLinkUp user ID (for account-id header)
  librePatientId  String?  // Patient ID for data retrieval
  region          String   @default("US") // 'US' | 'EU' | 'AP' (Asia-Pacific)

  // Sync settings
  autoSync        Boolean  @default(true)
  lastSyncAt      DateTime?
  syncFrequency   Int      @default(15) // minutes

  // Connection status
  isActive        Boolean  @default(true)
  lastError       String?  @db.Text

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
}

model ChatPreference {
  id                   String   @id @default(cuid())
  userId               String   @unique
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  communicationStyle   String   @default("warm")      // "warm" | "professional" | "casual"
  responseLength       String   @default("medium")    // "short" | "medium" | "detailed"
  enableNotifications  Boolean  @default(true)
  notificationTime     String?                        // "09:00"

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model AiUsage {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   // 'chat' | 'analyze-meal' | 'enhance-meal' | 'restaurant-tips' | etc.
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([createdAt])
}

// Post-meal check-in follow-up
model MealFollowUp {
  id            String    @id @default(cuid())
  mealId        String    @unique
  meal          Meal      @relation(fields: [mealId], references: [id], onDelete: Cascade)
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  scheduledFor  DateTime  // eatenAt + 2 hours
  status        String    @default("pending") // 'pending' | 'responded' | 'dismissed'
  response      String?   // 'ate_all' | 'ate_some' | 'didnt_eat' | 'changed_meal'
  portionEaten  Float?    // 0.0 - 1.0 (only set when response = 'ate_some')
  respondedAt   DateTime?

  createdAt     DateTime  @default(now())

  @@index([userId, status])
  @@index([userId, scheduledFor])
}

// Hydration / drink tracking
model HydrationLog {
  id       String   @id @default(cuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mealId   String?
  meal     Meal?    @relation(fields: [mealId], references: [id], onDelete: SetNull)
  loggedAt DateTime @default(now())

  drinkType            String   // water, coffee, tea, juice, soda, agua_fresca, electrolyte, broth, other
  amountOz             Float
  sweetened            Boolean?
  drinkCarbsG          Float?
  caffeine             Boolean?
  addToDailyWaterTotal Boolean  @default(true)

  @@index([userId, loggedAt])
  @@index([mealId])
}

// Daily guidance insights (gentle suggestions based on today's logs)
model GuidanceInsight {
  id       String   @id @default(cuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date     String   // YYYY-MM-DD

  type     String   // low_protein, low_fiber, low_water, high_added_sugar, high_sodium,
                    // carb_heavy_day, glp1_low_intake, low_glucose_safety, high_glucose_safety,
                    // meal_idea, snack_idea, mood_food_pattern
  message  String   @db.Text
  reason   String   @db.Text
  suggestedActions String? @db.Text // JSON array

  dismissed    Boolean @default(false)
  userFeedback String? // helpful, not_helpful, not_now

  createdAt DateTime @default(now())

  @@index([userId, date])
}

// Daily movement/activity log
model ActivityLog {
  id     String   @id @default(cuid())
  userId String
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date   DateTime @default(now())

  // What they did
  activityType      String?  // walking|strength|chores|dancing|sports|physical_work|stretching|chair_exercise|biking|swimming|other
  activityMinutes   Int?
  activityIntensity String?  // light|moderate|vigorous|not_sure
  steps             Int?

  // Meal relationship (optional — can link a walk to a meal)
  relatedToMeal Boolean @default(false)
  mealId        String? // soft link — no FK enforced for flexibility
  mealTiming    String? // before_meal|after_meal|not_related

  // Glucose context
  glucoseBeforeActivity Float?
  glucoseAfterActivity  Float?

  // How user felt
  energyBefore Int?     // 1–10
  energyAfter  Int?     // 1–10
  moodAfter    String?
  symptoms     String?  @db.Text  // JSON array
  notes        String?  @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, date])
  @@index([mealId])
}
